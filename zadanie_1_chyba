// PIC24FJ128GA010 Configuration Bit Settings
#pragma config POSCMOD = XT             // Primary Oscillator Select (XT Oscillator mode selected)
#pragma config OSCIOFNC = ON            // Primary Oscillator Output Function
#pragma config FCKSM = CSDCMD           // Clock Switching and Monitor
#pragma config FNOSC = PRI              // Oscillator Select (Primary Oscillator (XT, HS, EC))
#pragma config IESO = ON                // Internal External Switch Over Mode (IESO mode (Two-Speed Start-up) enabled)

#pragma config WDTPS = PS32768          // Watchdog Timer Postscaler (1:32,768)
#pragma config FWPSA = PR128            // WDT Prescaler (Prescaler ratio of 1:128)
#pragma config WINDIS = ON              // Watchdog Timer Window (Standard Watchdog Timer enabled)
#pragma config FWDTEN = ON              // Watchdog Timer Enable (Watchdog Timer is enabled)
#pragma config ICS = PGx2               // Comm Channel Select (Emulator/debugger uses EMUC2/EMUD2)
#pragma config GWRP = OFF               // General Code Segment Write Protect
#pragma config GCP = OFF                // General Code Segment Code Protect
#pragma config JTAGEN = OFF             // JTAG Port Enable

#include "xc.h"
#include "libpic30.h" // biblioteka do opóźnień
#include <stdint.h> 

// --- DEKLARACJE FUNKCJI ---
void zwiekszenie(void);
void zmniejszenie(void);
void gray_w_gore(void);
void gray_w_dol(void);
void bcd_w_gore(void);
void bcd_w_dol(void);
void wenszyk(void);
void kolejka(void);
void lfsr(void);

// --- FUNKCJA GŁÓWNA ---
int main(void) {
    
    // 1. Konfiguracja Portów
    AD1PCFG = 0xFFFF;       // port A ustawiony na cyfrowy
    TRISA = 0x0000;         // ustawiamy port A na wyjście (diody)
    LATA = 0x0000;          // wygaszenie na start

    // Konfiguracja przycisków (np. RD6 i RD13 jak we wcześniejszym zadaniu)
    TRISDbits.TRISD6 = 1;   // Następny
    TRISDbits.TRISD13 = 1;  // Poprzedni

    // Zmienne sterujące
    int prog = 1;           // Aktualny program (1-9)
    int prev_d6 = 1;
    int prev_d13 = 1;
    int timer = 0;

    while(1) {
        // Obsługa przycisków
        int current_d6 = PORTDbits.RD6;
        int current_d13 = PORTDbits.RD13;

        if (current_d6 == 0 && prev_d6 == 1) { 
            prog++;
            if (prog > 9) prog = 1;
            __delay32(30000); // drgania styków
        }
        if (current_d13 == 0 && prev_d13 == 1) { 
            prog--;
            if (prog < 1) prog = 9;
            __delay32(30000); // drgania styków
        }
        
        prev_d6 = current_d6;
        prev_d13 = current_d13;

        // Wywołanie funkcji z odpowiednim opóźnieniem (co ok. 15 obiegów pętli)
        timer++;
        if (timer >= 15) {
            timer = 0;
            
            // Przełącznik wywołujący odpowiednią funkcję
            switch(prog) {
                case 1: zwiekszenie(); break;
                case 2: zmniejszenie(); break;
                case 3: gray_w_gore(); break;
                case 4: gray_w_dol(); break;
                case 5: bcd_w_gore(); break;
                case 6: bcd_w_dol(); break;
                case 7: wenszyk(); break;
                case 8: kolejka(); break;
                case 9: lfsr(); break;
            }
        }

        // Małe opóźnienie pętli głównej (nie blokuje przycisków tak jak wielkie delaye)
        __delay32(50000); 
    }
    
    return -1;
}

// --- TWOJE PODPROGRAMY (zmodyfikowane do działania asynchronicznego) ---

void zwiekszenie() {
    static unsigned char numer = 0; 
    LATA = numer++;
}

void zmniejszenie() {
    static unsigned char numer = 255;
    LATA = numer--;
}

void gray_w_gore() {
    static unsigned char numer = 0;
    LATA = numer ^ (numer >> 1); // konwersja do kodu Graya
    numer++;
}

void gray_w_dol() {
    static unsigned char numer = 255;
    LATA = numer ^ (numer >> 1); // konwersja do kodu Graya
    numer--;
}

void bcd_w_gore() {
    static unsigned char jednosci = 0;  
    static unsigned char dziesiatki = 0; 
    
    LATA = (dziesiatki << 4) | jednosci;

    jednosci++;
    if(jednosci > 9) {
        jednosci = 0;
        dziesiatki++;
        if(dziesiatki > 9) dziesiatki = 0; 
    }
}

void bcd_w_dol() {
    static unsigned char jednosci = 9;
    static unsigned char dziesiatki = 9;

    LATA = (dziesiatki << 4) | jednosci;

    if(jednosci == 0) {
        jednosci = 9;
        if(dziesiatki == 0) dziesiatki = 9; 
        else dziesiatki--;
    } else {
        jednosci--;
    }
}

void wenszyk() {
    static unsigned char numer = 0x07; // 3 bity tak jak w Twoim komentarzu
    static int kierunek = 1; 

    LATA = numer;

    if(kierunek == 1) {
        numer <<= 1;
        if(numer == 0xE0) kierunek = -1;
    } else {
        numer >>= 1;
        if(numer == 0x07) kierunek = 1;
    }
}

void kolejka() {
    // Użyto Twojej implementacji, dodałem tylko reset po zapełnieniu całego paska
    static unsigned char numer = 0x00;

    LATA = numer;
    numer = (numer << 1) | 0x01; // dodajemy "1" na końcu
    
    if (numer == 0xFF) { // Jeśli całe się zapali
        LATA = numer;    // Wyświetl pełne
        numer = 0x00;    // Zresetuj w następnym kroku
    }
}

void lfsr() {
    // Twoja implementacja z seed = 0x3F
    static unsigned char my_lfsr = 0x3F; 
    
    LATA = my_lfsr;

    // XOR wybranych bitów (dla 1110011)
    unsigned char newbit = ((my_lfsr >> 5) ^ (my_lfsr >> 4) ^ (my_lfsr >> 1) ^ (my_lfsr >> 0)) & 1;
    my_lfsr = (my_lfsr >> 1) | (newbit << 5);
}